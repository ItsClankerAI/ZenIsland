{
  "sections": [
    {
      "title": "Timer",
      "fields": [
        {
          "type": "slider",
          "key": "workDuration",
          "label": "Work duration (min)",
          "min": 5,
          "max": 90,
          "step": 5,
          "default": 25
        },
        {
          "type": "slider",
          "key": "breakDuration",
          "label": "Break duration (min)",
          "min": 1,
          "max": 30,
          "step": 1,
          "default": 5
        }
      ]
    },
    {
      "title": "Notch Outline",
      "fields": [
        {
          "type": "color",
          "key": "focusOutlineColor",
          "label": "Focus outline color",
          "default": "#FFAD42"
        },
        {
          "type": "picker",
          "key": "focusOutlineMode",
          "label": "Focus progress mode",
          "default": "elapsed",
          "options": [
            {
              "value": "elapsed",
              "label": "Elapsed fills up"
            },
            {
              "value": "remaining",
              "label": "Remaining drains down"
            }
          ]
        },
        {
          "type": "color",
          "key": "breakOutlineColor",
          "label": "Rest outline color",
          "default": "#66DE8C"
        },
        {
          "type": "picker",
          "key": "breakOutlineMode",
          "label": "Rest progress mode",
          "default": "elapsed",
          "options": [
            {
              "value": "elapsed",
              "label": "Elapsed fills up"
            },
            {
              "value": "remaining",
              "label": "Remaining drains down"
            }
          ]
        }
      ]
    },
    {
      "title": "Notifications",
      "fields": [
        {
          "type": "toggle",
          "key": "notifyOnComplete",
          "label": "Notify when phase ends",
          "default": true
        },
        {
          "type": "toggle",
          "key": "playSound",
          "label": "Play notification sound",
          "default": true
        }
      ]
    }
  ]
}
